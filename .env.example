# 0g Mem — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ─── Wallet (required) ────────────────────────────────────────────────────────
AGENT_KEY=0x_your_private_key_here
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ─── Deployed contracts (filled after running: make deploy) ───────────────────
MEMORY_REGISTRY_ADDRESS=
MEMORY_NFT_ADDRESS=

# ─── 0g DA node (for docker-compose) ─────────────────────────────────────────
# Used by envfile.env — the DA Docker node reads these directly
COMBINED_SERVER_CHAIN_RPC=https://evmrpc-testnet.0g.ai
COMBINED_SERVER_PRIVATE_KEY=your_private_key_without_0x_prefix

# ─── Agent Runtime ─────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# WebSocket URL for memory service (default: local dev)
MEMORY_WS_URL=ws://localhost:8000
# Inference API keys (optional — falls back to 0g Serving)
OPENAI_API_KEY=
ZHIPU_API_KEY=
# Web search (optional — DuckDuckGo HTML is used by default if Tavily key not set)
TAVILY_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
