# 0g Mem — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ─── Wallet (required) ────────────────────────────────────────────────────────
AGENT_KEY=0x_your_private_key_here
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ─── Deployed contracts (filled after running: make deploy) ───────────────────
MEMORY_REGISTRY_ADDRESS=
MEMORY_NFT_ADDRESS=

# ─── 0g DA node (for docker-compose) ─────────────────────────────────────────
# Used by envfile.env — the DA Docker node reads these directly
COMBINED_SERVER_CHAIN_RPC=https://evmrpc-testnet.0g.ai
COMBINED_SERVER_PRIVATE_KEY=your_private_key_without_0x_prefix

# ─── 0g Compute Inference ────────────────────────────────────────────────────
# Option A — Local proxy (recommended for demo):
#   1. Install: pnpm add @0glabs/0g-serving-broker -g
#   2. Fund: 0g-compute-cli deposit --amount 10
#   3. Transfer: 0g-compute-cli transfer-fund --provider <ADDR> --amount 1
#   4. Serve locally: 0g-compute-cli inference serve --provider <ADDR> --port 3000
#   Then set:
OG_COMPUTE_LOCAL_PROXY=http://localhost:3000

# Option B — Direct API key (if not using local proxy):
#   Get secret: 0g-compute-cli inference get-secret --provider <ADDR>
#   Get service URL: 0g-compute-cli inference list-providers
# Then set both:
# OG_COMPUTE_SERVICE_URL=https://...
# OG_COMPUTE_API_KEY=app-sk-...

# OpenAI fallback (used if 0g is unavailable)
OPENAI_API_KEY=

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Memory / WebSocket ─────────────────────────────────────────────────────────
MEMORY_WS_URL=ws://localhost:8000

# ─── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=  # Optional — DuckDuckGo HTML used by default if not set

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
